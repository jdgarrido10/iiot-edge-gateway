# ══════════════════════════════════════════════════════════════════════════════
# 🔐 CONFIGURACIÓN DEL SISTEMA IIoT
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 🌍 CONFIGURACIÓN GENERAL
# ─────────────────────────────────────────────────────────────────────────────
TIMEZONE=Europe/Madrid

# ─────────────────────────────────────────────────────────────────────────────
# 📡 MQTT (Mosquitto)
# ─────────────────────────────────────────────────────────────────────────────
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=factory/#
MQTT_QOS=1
MQTT_KEEPALIVE=60

# ─────────────────────────────────────────────────────────────────────────────
# 🗄️ MINIO (Data Lake S3-compatible)
# ─────────────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=admin
MINIO_BUCKET=raw-data
MINIO_SECURE=false
MINIO_ROOT_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# 📊 INFLUXDB (Time Series Database)
# ─────────────────────────────────────────────────────────────────────────────
INFLUX_URL=http://influxdb:8086
INFLUX_USER=admin
INFLUX_PASSWORD=

DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_ORG=Cooperativa
DOCKER_INFLUXDB_INIT_BUCKET=sensores
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=

INFLUX_TIMEOUT=30000
INFLUX_WRITE_BATCH_SIZE=5000

# ─────────────────────────────────────────────────────────────────────────────
# 📈 GRAFANA (Credenciales UI)
# ─────────────────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=
GF_SECURITY_ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# ⚙️ WORKER - Configuración de Procesamiento
# ─────────────────────────────────────────────────────────────────────────────
BATCH_SIZE=1000
BATCH_TIMEOUT=20
MAX_BUFFER_SIZE=10000
ROLLOVER_THRESHOLD=1000
IO_THREAD_POOL_SIZE=4
PROCESSING_THREAD_POOL_SIZE=2
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
MAX_WORKERS_PER_LINE=100

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 API SERVER / GRAFANA
# ─────────────────────────────────────────────────────────────────────────────
API_PORT=8765
PROMETHEUS_PORT=9091
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# 🪵 LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
DEBUG=true 

# ─────────────────────────────────────────────────────────────────────────────
# 🔧 LÍMITES DE RECURSOS (Docker Deploy)
# ─────────────────────────────────────────────────────────────────────────────
INFLUX_CPU_LIMIT=2.0
INFLUX_MEM_LIMIT=2G

MINIO_CPU_LIMIT=1.0
MINIO_MEM_LIMIT=1G

WORKER_CPU_LIMIT=0.5
WORKER_MEM_LIMIT=512M

MQTT_CPU_LIMIT=0.5
MQTT_MEM_LIMIT=512M

# GRAFANA
GRAFANA_CPU_LIMIT=0.5
GRAFANA_MEM_LIMIT=512M

# NODE-RED
NODERED_CPU_LIMIT=0.5
NODERED_MEM_LIMIT=512M

# SMTP Correo
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_SENDER=
SMTP_PASSWORD=
SMTP_FROM_NAME=""